{
  "manifest_version": 3,
  "name": "状态刷新",
  "version": "1.0.0",
  "description": "检测目标网站，连续停留超过设定时间后自动关闭标签页",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "网站限时守护"
  },
  "icons": {}
}